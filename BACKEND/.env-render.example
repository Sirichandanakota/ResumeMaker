# RENDER Environment Variables Reference
# These values must be set in Render Dashboard (NOT in .env file)
# Copy each line exactly as shown

# Production Environment Flag
NODE_ENV=production

# Server Port (Render assigns dynamically, but we reference 5000)
PORT=5000

# MongoDB Connection String
# IMPORTANT: Make sure your cluster allows your IP (preferably all IPs)
MONGODB_URI=mongodb+srv://kotasirichandana7:chandana2082@resumemaker.myex2ke.mongodb.net/resumemaker

# JWT Secret for Token Signing
# ⚠️ IMPORTANT: Generate a strong random string (min 32 characters)
# DO NOT use the example below in production!
JWT_SECRET=change-this-to-a-strong-random-secret-key-minimum-32-characters

# Frontend URL (set after Vercel deployment)
# Example: https://resume-maker-app.vercel.app
# Leave empty initially, add after frontend is deployed
FRONTEND_URL=

# Optional: Logging Level (for debugging)
# LOG_LEVEL=debug
